# Copy this file to .env and fill in the values
# .env is gitignored and should never be committed

# Required for docker compose (production environment).
# Get the value from config/credentials/production.key (or from your team's password manager).
RAILS_MASTER_KEY_PRODUCTION=

# Development key is committed at config/credentials/development.key — no action needed locally.
# RAILS_MASTER_KEY_DEVELOPMENT=

# Database (matches docker-compose defaults, change for production)
POSTGRES_USER=profind
POSTGRES_PASSWORD=profind_password
POSTGRES_DB=profind_production
