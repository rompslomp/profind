<h1 class="mb-4">Admin Dashboard</h1>

<div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
  <div class="col">
    <div class="card text-bg-primary shadow-sm h-100">
      <div class="card-body text-center">
        <h2 class="display-4"><%= @total_users %></h2>
        <p class="mb-0">Total Users</p>
      </div>
      <div class="card-footer text-center">
        <%= link_to "Manage", admin_users_path, class: "btn btn-light btn-sm" %>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-bg-warning shadow-sm h-100">
      <div class="card-body text-center">
        <h2 class="display-4"><%= @pending_requests %></h2>
        <p class="mb-0">Pending Requests</p>
      </div>
      <div class="card-footer text-center">
        <%= link_to "Review", admin_provider_requests_path, class: "btn btn-dark btn-sm" %>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-bg-success shadow-sm h-100">
      <div class="card-body text-center">
        <h2 class="display-4"><%= @total_providers %></h2>
        <p class="mb-0">Active Providers</p>
      </div>
      <div class="card-footer text-center">
        <%= link_to "View", admin_users_path, class: "btn btn-light btn-sm" %>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-bg-info shadow-sm h-100">
      <div class="card-body text-center">
        <h2 class="display-4"><%= @total_services %></h2>
        <p class="mb-0">Listed Services</p>
      </div>
      <div class="card-footer text-center">
        <%= link_to "View All", services_path, class: "btn btn-light btn-sm" %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Quick Actions</h5>
      </div>
      <div class="list-group list-group-flush">
        <%= link_to admin_provider_requests_path, class: "list-group-item list-group-item-action d-flex justify-content-between" do %>
          Review Provider Requests
          <% if @pending_requests > 0 %>
            <span class="badge bg-warning text-dark"><%= @pending_requests %></span>
          <% end %>
        <% end %>
        <%= link_to "Manage Tags", admin_tags_path, class: "list-group-item list-group-item-action" %>
        <%= link_to "Manage Users", admin_users_path, class: "list-group-item list-group-item-action" %>
      </div>
    </div>
  </div>
</div>
