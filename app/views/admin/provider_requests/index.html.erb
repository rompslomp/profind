<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Provider Requests</h1>
  <span class="badge bg-warning text-dark fs-6"><%= @users.count %> pending</span>
</div>

<% if @users.empty? %>
  <div class="alert alert-info">No pending provider requests.</div>
<% else %>
  <div class="table-responsive">
    <table class="table table-hover table-striped align-middle">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Requested</th>
          <th>Bio</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><strong><%= user.name %></strong></td>
            <td><%= user.email %></td>
            <td><%= user.updated_at.strftime("%b %d, %Y") %></td>
            <td><%= truncate(user.provider_bio, length: 80) || "—" %></td>
            <td class="text-end">
              <%= button_to "Approve", approve_admin_provider_request_path(user), method: :patch,
                    class: "btn btn-success btn-sm",
                    data: { turbo_confirm: "Approve #{user.name} as a provider?" } %>
              <%= button_to "Reject", reject_admin_provider_request_path(user), method: :patch,
                    class: "btn btn-danger btn-sm ms-1",
                    data: { turbo_confirm: "Reject #{user.name}'s request?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
