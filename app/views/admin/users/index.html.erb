<h1 class="mb-4">Manage Users</h1>

<%= search_form_for @q, url: admin_users_path, class: "mb-4" do |f| %>
  <div class="input-group">
    <%= f.search_field :name_or_email_cont, placeholder: "Search by name or email...", class: "form-control" %>
    <%= f.submit "Search", class: "btn btn-outline-secondary" %>
    <%= link_to "Clear", admin_users_path, class: "btn btn-outline-danger" %>
  </div>
<% end %>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Provider Status</th>
        <th>Joined</th>
        <th class="text-end">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><strong><%= user.name %></strong></td>
          <td><%= user.email %></td>
          <td>
            <span class="badge <%= user.admin? ? 'bg-danger' : user.provider? ? 'bg-success' : 'bg-secondary' %>">
              <%= user.role.capitalize %>
            </span>
          </td>
          <td>
            <span class="badge <%= user.approved? ? 'bg-success' : user.pending? ? 'bg-warning text-dark' : user.rejected? ? 'bg-danger' : 'bg-light text-dark' %>">
              <%= user.provider_status.humanize %>
            </span>
          </td>
          <td><%= user.created_at.strftime("%b %d, %Y") %></td>
          <td class="text-end">
            <%= link_to "View", admin_user_path(user), class: "btn btn-outline-primary btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
