<% content_for :title, "Find Professionals" %>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
          <h6 class="mb-0">Filter &amp; Search</h6>
        </div>
        <div class="card-body">
          <%= form_with url: services_path, method: :get do |f| %>
            <div class="mb-3">
              <%= f.label :q, "Keywords", class: "form-label" %>
              <%= f.text_field :q, value: params[:q], placeholder: "e.g. plumber, painting...", class: "form-control" %>
            </div>
            <div class="mb-3">
              <%= f.label :tag_id, "Category", class: "form-label" %>
              <%= f.select :tag_id,
                    options_from_collection_for_select(@tags, :id, :name, params[:tag_id]),
                    { include_blank: "All categories" },
                    class: "form-select" %>
            </div>
            <%= f.submit "Search", class: "btn btn-primary w-100" %>
            <% if params[:q].present? || params[:tag_id].present? %>
              <%= link_to "Clear filters", services_path, class: "btn btn-outline-secondary w-100 mt-2" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
          <% if @my_services %>
            My Services
          <% elsif @selected_tag %>
            Professionals: <span class="badge bg-primary"><%= @selected_tag.name %></span>
          <% elsif params[:q].present? %>
            Results for "<%= params[:q] %>"
          <% else %>
            All Professionals
          <% end %>
        </h1>
        <div class="d-flex align-items-center gap-2">
          <span class="text-muted"><%= @services.count %> found</span>
          <% if @my_services %>
            <%= link_to "Add Service", new_service_path, class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      </div>

      <% if @services.empty? %>
        <div class="text-center py-5 text-muted">
          <p class="fs-5">No services found matching your search.</p>
          <%= link_to "Browse all", services_path, class: "btn btn-outline-primary" %>
        </div>
      <% else %>
        <div class="row row-cols-1 row-cols-md-2 g-4">
          <% @services.each do |service| %>
            <div class="col">
              <div class="card h-100 shadow-sm">
                <% if service.images.attached? %>
                  <%= image_tag service.images.first, class: "card-img-top", style: "height: 180px; object-fit: cover;" %>
                <% else %>
                  <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                    <span class="text-muted fs-1">&#128296;</span>
                  </div>
                <% end %>
                <div class="card-body">
                  <h5 class="card-title"><%= service.title %></h5>
                  <p class="text-muted small mb-2">by <%= service.user.name %></p>
                  <p class="card-text"><%= truncate(service.description, length: 120) %></p>
                  <% if service.tags.any? %>
                    <div>
                      <% service.tags.each do |tag| %>
                        <%= link_to tag.name, services_path(tag_id: tag.id), class: "badge bg-secondary text-decoration-none me-1" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
                <div class="card-footer bg-transparent">
                  <%= link_to "View & Request Quote", service_path(service), class: "btn btn-primary btn-sm w-100" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
