<% content_for :title, "My Quote Requests" %>

<div class="container mt-4">
  <h1 class="mb-4">My Quote Requests</h1>

  <% if @quotes.empty? %>
    <div class="text-center py-5 text-muted">
      <p class="fs-5">You haven't made any quote requests yet.</p>
      <%= link_to "Find Professionals", services_path, class: "btn btn-primary" %>
    </div>
  <% else %>
    <div class="list-group shadow-sm">
      <% @quotes.each do |quote| %>
        <div class="list-group-item">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h6 class="mb-1"><%= link_to quote.service.title, service_path(quote.service) %></h6>
              <p class="mb-1 text-muted small"><%= truncate(quote.message, length: 100) %></p>
              <small class="text-muted">Submitted <%= time_ago_in_words(quote.created_at) %> ago</small>
            </div>
            <div class="d-flex flex-column align-items-end gap-2">
              <span class="badge <%= quote.pending? ? 'bg-warning text-dark' : quote.responded? ? 'bg-success' : 'bg-secondary' %>">
                <%= quote.status.capitalize %>
              </span>
              <div class="d-flex gap-1">
                <%= link_to "View", quote_path(quote), class: "btn btn-outline-primary btn-sm" %>
                <%= button_to "Delete", quote_path(quote), method: :delete, class: "btn btn-outline-danger btn-sm",
                      data: { turbo_confirm: "Delete this quote request?" } %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
