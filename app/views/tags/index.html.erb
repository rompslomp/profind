<% content_for :title, "Browse by Category" %>

<div class="container mt-4">
  <h1 class="mb-4">Browse by Category</h1>

  <% if @tags.empty? %>
    <div class="text-center py-5 text-muted">
      <p class="fs-5">No categories yet.</p>
    </div>
  <% else %>
    <div class="d-flex flex-wrap gap-2">
      <% @tags.each do |tag| %>
        <%= link_to services_path(tag_id: tag.id), class: "btn btn-outline-primary" do %>
          <%= tag.name %>
          <span class="badge bg-primary ms-1"><%= tag.services.count %></span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
